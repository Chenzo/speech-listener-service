{
  "name": "stream-voice-triggers",
  "version": "1.3.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:transcriber": "powershell -ExecutionPolicy Bypass -File scripts/build-transcriber.ps1",
    "build:obs-overlay": "powershell -ExecutionPolicy Bypass -File scripts/build-obs-overlay.ps1",
    "install-model": "powershell -ExecutionPolicy Bypass -File scripts/install-model.ps1",
    "pack": "npm run build:transcriber && electron-builder --dir",
    "dist": "npm run build:transcriber && electron-builder --win portable && npm run build:obs-overlay",
    "start": "node index.js",
    "start:electron": "electron electron/main.js",
    "start:electron:mac": "PYTHON=$PWD/.venv/bin/python electron electron/main.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^39.8.6",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.streamvoicetriggers.app",
    "productName": "Stream Voice Triggers",
    "asar": false,
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "files": [
      "electron/**/*",
      "index.js",
      "settings-defaults.js",
      "transcribe.py",
      "stream-voice-triggers.ico",
      "stream-voice-triggers.png",
      "package.json",
      "!models/**",
      "!.stream-voice-triggers-config.json"
    ],
    "extraResources": [
      {
        "from": "release-assets/transcribe",
        "to": "transcribe"
      }
    ],
    "win": {
      "icon": "stream-voice-triggers.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
